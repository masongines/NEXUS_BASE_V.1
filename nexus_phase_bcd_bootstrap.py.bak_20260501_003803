""")

# -----------------------------------
# 7. SYSTEM STATE
# -----------------------------------
def create_system_state_files():
    write_file(ROOT / "03_system_state/context_export_status.md", """
# CONTEXT EXPORT STATUS

Not fully stabilized  
Authority: Observational only  
Requires Phase C/D validation  
""")

# -----------------------------------
# 8. AEGIS
# -----------------------------------
def create_aegis_adapter():
    write_file(ROOT / "02_config/aegis_interface/aegis_adapter.py", """
def format_aegis_advisory(domain, suggestion):
    return {
        "type": "AEGIS_ADVISORY",
        "domain": domain,
        "suggestion": suggestion,
        "authority": "NON_EXECUTABLE"
    }
""")

# -----------------------------------
# 9. LOG INIT
# -----------------------------------
def initialize_log_file():
    log_file = ROOT / "04_logs/execution/log.txt"
    if not log_file.exists():
        log_file.touch()
        log_created(log_file)
    else:
        log_skipped(log_file)

# -----------------------------------
# 10. TEST
# -----------------------------------
def run_validation_test():
    print("\\nRunning validation test...")
    subprocess.run([sys.executable, str(ROOT / "01_core/execution/executor.py")])

# -----------------------------------
# MAIN
# -----------------------------------
def main():
    verify_root_structure()
    create_directory_structure()
    create_execution_files()
    create_config_files()
    create_governance_files()
    create_system_state_files()
    create_aegis_adapter()
    initialize_log_file()

    print("\\n--- SUMMARY ---")
    print("CREATED:", *CREATED, sep="\\n- ")
    print("\\nSKIPPED:", *SKIPPED, sep="\\n- ")
    print("\\nFAILED:", *FAILED, sep="\\n- ")

    run_validation_test()

if __name__ == "__main__":
    main()