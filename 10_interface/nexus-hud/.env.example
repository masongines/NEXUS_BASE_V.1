# NEXUS HUD — environment variables (sample)
#
# Copy to .env.local for local dev. Vite only exposes VITE_* prefixed vars
# to the client.

# Base URL for nexus-api. In production (Docker), nginx proxies /api/* to
# the host, so this stays as "/api". In dev (Vite), point directly at the
# Pi or local nexus-api instance.
VITE_NEXUS_API_BASE_URL=/api

# Pieces OS local API (Stage 6 — defer)
# VITE_PIECES_OS_URL=http://localhost:39300
